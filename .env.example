NEXT_PUBLIC_DEFAULT_UID=58856059-c4fd-4626-aea7-42aefc048eec

# REST fallback, only if a JSON endpoint is later provided by LiveTime/LapTime.
LIVETIME_ENDPOINT=
LIVETIME_TIMEOUT_MS=3000

# Recommended production path: persistent scraper process exposes this URL.
# Example local scraper: http://localhost:4010/api/livetime-snapshot
LIVETIME_SNAPSHOT_ENDPOINT=
LIVETIME_CACHE_TTL_MS=10000

# Scraper process variables used by `npm run scraper`.
LIVETIME_UID=58856059-c4fd-4626-aea7-42aefc048eec
LIVETIME_HEADLESS=true
LIVETIME_SCRAPER_POLL_MS=2000
SCRAPER_PORT=4010
