NEXT_PUBLIC_DEFAULT_UID=58856059-c4fd-4626-aea7-42aefc048eec

# REST fallback, only if a JSON endpoint is later provided by LiveTime/LapTime.
LIVETIME_ENDPOINT=
LIVETIME_TIMEOUT_MS=3000

# Recommended production path: persistent scraper process exposes this URL.
# Example local scraper: http://localhost:4010/api/livetime-snapshot
LIVETIME_SNAPSHOT_ENDPOINT=
LIVETIME_CACHE_TTL_MS=10000

# Scraper process variables used by `npm run scraper`.
LIVETIME_UID=58856059-c4fd-4626-aea7-42aefc048eec
LIVETIME_HEADLESS=true
LIVETIME_SCRAPER_POLL_MS=2000
SCRAPER_PORT=4010

# === AIOX Variables (added 2026-05-07) ===
# Cost: ~$0.14/M tokens with tool calling support
DEEPSEEK_API_KEY=
# Get your key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
# OpenAI API Key - Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Get your key at: https://exa.ai/
EXA_API_KEY=
# Usually free, no key required for basic usage
CONTEXT7_API_KEY=
# Get from your Supabase project settings
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Create at: https://github.com/settings/tokens
GITHUB_TOKEN=
# Get from: ClickUp Settings > Apps > API Token
CLICKUP_API_KEY=
# From your N8N instance settings
N8N_API_KEY=
N8N_WEBHOOK_URL=
# Sentry (error tracking)
SENTRY_DSN=
# Railway (deployment)
RAILWAY_TOKEN=
# Vercel (deployment)
VERCEL_TOKEN=
# --------------------------------------------
NODE_ENV=development
AIOX_VERSION=5.1.15
